# =============================================================================
# AfyaSasa — environment template (copy to .env and adjust per environment)
# =============================================================================

# --- Application ---
NODE_ENV=development
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173

# --- PostgreSQL ---
POSTGRES_DB=afyasasa
POSTGRES_USER=afyasasa
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DEFAULT_TENANT_SCHEMA=demo
TYPEORM_MIGRATIONS_RUN=true

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- JWT (use long random strings in production) ---
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Object storage (MinIO / S3 / R2 / Azure Blob) ---
MINIO_ROOT_USER=afyasasa
MINIO_ROOT_PASSWORD=change-me-minio-password
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=afyasasa
S3_SECRET_ACCESS_KEY=change-me-s3-secret
S3_BUCKET=afyasasa-clinical-files
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# --- SMS ---
SMS_PROVIDER=stub
SMS_SENDER_NAME=AfyaSasa
AFRICAS_TALKING_USERNAME=sandbox
AFRICAS_TALKING_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Email (when implemented) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@your-hospital.local

# --- Frontend build (set in frontend/.env or Docker build args) ---
# VITE_API_BASE_URL=/api/v1
# VITE_SOCKET_URL=

# =============================================================================
# Production notes
# =============================================================================
# 1. Set NODE_ENV=production
# 2. Use strong secrets for JWT, Postgres, MinIO, and S3 credentials
# 3. Point FRONTEND_ORIGIN to your public URL (e.g. https://emr.hospital.go.ke)
# 4. Behind Nginx/Cloudflare: VITE_API_BASE_URL=/api/v1 (relative path via proxy)
# 5. Set SMS_PROVIDER to africas_talking or twilio when ready
# 6. Run: npm run preflight && docker compose up -d --build
# 7. Health: GET /api/v1/health and admin system health endpoint
