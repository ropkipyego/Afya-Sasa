# Frontend build-time settings (copy to frontend/.env for local Vite dev)

# API base — use relative path when served via Nginx on :8080
VITE_API_BASE_URL=/api/v1

# --- Single-hospital mode (hide "Hospital code" on login) ---
# Set both for one hospital; users only enter email + password.
VITE_DEFAULT_TENANT=demo
VITE_HIDE_TENANT_SELECTOR=true
